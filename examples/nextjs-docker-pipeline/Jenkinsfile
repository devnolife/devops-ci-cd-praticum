pipeline {
    agent any

    environment {
        APP_DIR = 'semester 5/cloud-native-practicum/examples/nextjs-docker-app'
        IMAGE_NAME = 'nextjs-docker-app'
        CONTAINER_NAME = "nextjs-docker-app-${BUILD_NUMBER}"
    }

    stages {
        stage('Install') {
            steps {
                dir(env.APP_DIR) {
                    sh 'npm ci'
                }
            }
        }

        stage('Test') {
            steps {
                dir(env.APP_DIR) {
                    sh 'npm test'
                }
            }
        }

        stage('Build Next.js') {
            steps {
                dir(env.APP_DIR) {
                    sh 'npm run build'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir(env.APP_DIR) {
                    sh "docker build -t ${IMAGE_NAME}:${BUILD_NUMBER} ."
                }
            }
        }

        stage('Smoke Test Container') {
            steps {
                dir(env.APP_DIR) {
                    sh '''
                        docker run -d --name "$CONTAINER_NAME" -p 3000:3000 \
                          -e APP_ENV=ci \
                          -e APP_VERSION="$BUILD_NUMBER" \
                          "$IMAGE_NAME:$BUILD_NUMBER"

                        for i in $(seq 1 20); do
                          if docker exec "$CONTAINER_NAME" node -e "fetch('http://127.0.0.1:3000/api/health').then((res) => { if (!res.ok) process.exit(1); }).catch(() => process.exit(1));"; then
                            exit 0
                          fi
                          sleep 2
                        done

                        docker logs "$CONTAINER_NAME"
                        exit 1
                    '''
                }
            }
            post {
                always {
                    sh 'docker rm -f "$CONTAINER_NAME" || true'
                }
            }
        }
    }
}
